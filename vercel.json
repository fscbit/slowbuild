{
  "functions": {
    "api/order.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "redirects": [
    { "source": "/:path*", "has": [{ "type": "host", "value": "slowbuild.top" }], "destination": "https://www.slowbuild.top/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" }
  ]
}
